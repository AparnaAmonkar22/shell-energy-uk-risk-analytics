{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "aparna-adf-shellenergy-uk"
		},
		"ap_AKV_shellenergyuks_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-bd-training-uk.vault.azure.net/"
		},
		"ap_ls_adls_shellenergy_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://aparnastshellenergyuks.dfs.core.windows.net"
		},
		"ap_ls_http_github_raw_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/AparnaAmonkar22/shell-energy-uk-risk-analytics/main/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "aparna-adf-shellenergy-uk_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ap_AKV_shellenergyuks_properties_typeProperties_baseUrl": {
						"value": "[parameters('ap_AKV_shellenergyuks_properties_typeProperties_baseUrl')]"
					},
					"ap_ls_http_github_raw_properties_typeProperties_url": {
						"value": "[parameters('ap_ls_http_github_raw_properties_typeProperties_url')]"
					},
					"ap_ls_adls_shellenergy_properties_typeProperties_url": {
						"value": "[parameters('ap_ls_adls_shellenergy_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}